<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>毛概复习助手</display-name>

    <!-- 字符编码过滤器 -->
    <filter>
        <filter-name>encodingFilter</filter-name>
        <filter-class>com.maogai.util.CharacterEncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>authFilter</filter-name>
        <filter-class>com.maogai.util.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>authFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 欢迎页面 -->
    <welcome-file-list>
        <welcome-file>index</welcome-file>
    </welcome-file-list>

    <!-- 首页路由 -->
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.maogai.servlet.IndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/index</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.maogai.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/auth/*</url-pattern>
    </servlet-mapping>

    <!-- 章节大纲Servlet -->
    <servlet>
        <servlet-name>OutlineServlet</servlet-name>
        <servlet-class>com.maogai.servlet.OutlineServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OutlineServlet</servlet-name>
        <url-pattern>/api/outline/*</url-pattern>
    </servlet-mapping>

    <!-- 速记卡片Servlet -->
    <servlet>
        <servlet-name>FlashcardServlet</servlet-name>
        <servlet-class>com.maogai.servlet.FlashcardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FlashcardServlet</servlet-name>
        <url-pattern>/api/flashcards/*</url-pattern>
    </servlet-mapping>

    <!-- 题库Servlet -->
    <servlet>
        <servlet-name>QuizServlet</servlet-name>
        <servlet-class>com.maogai.servlet.QuizServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QuizServlet</servlet-name>
        <url-pattern>/api/quiz/*</url-pattern>
    </servlet-mapping>

    <!-- 错题本Servlet -->
    <servlet>
        <servlet-name>WrongBookServlet</servlet-name>
        <servlet-class>com.maogai.servlet.WrongBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WrongBookServlet</servlet-name>
        <url-pattern>/api/wrong/*</url-pattern>
    </servlet-mapping>

    <!-- AI服务Servlet -->
    <servlet>
        <servlet-name>AIServlet</servlet-name>
        <servlet-class>com.maogai.servlet.AIServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AIServlet</servlet-name>
        <url-pattern>/api/ai/*</url-pattern>
    </servlet-mapping>

    <!-- 题目导入Servlet -->
    <servlet>
        <servlet-name>ImportServlet</servlet-name>
        <servlet-class>com.maogai.servlet.ImportServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size>
            <max-request-size>20971520</max-request-size>
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImportServlet</servlet-name>
        <url-pattern>/api/import/*</url-pattern>
    </servlet-mapping>

    <!-- JSP页面路由 -->
    <servlet>
        <servlet-name>PageServlet</servlet-name>
        <servlet-class>com.maogai.servlet.PageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PageServlet</servlet-name>
        <url-pattern>/page/*</url-pattern>
    </servlet-mapping>

    <!-- 会话超时30分钟 -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- MIME映射 -->
    <mime-mapping>
        <extension>json</extension>
        <mime-type>application/json</mime-type>
    </mime-mapping>

</web-app>
